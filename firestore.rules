rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function to validate string length
    function validStringLength(field, minLen, maxLen) {
      return request.resource.data[field] is string &&
        request.resource.data[field].size() >= minLen &&
        request.resource.data[field].size() <= maxLen;
    }

    // Helper function to validate required fields
    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    // Domain Validators
    function isValidStudent(data) {
      return hasRequiredFields(['firstName', 'lastName', 'grade']) &&
             validStringLength('firstName', 1, 100) &&
             validStringLength('lastName', 1, 100) &&
             validStringLength('grade', 1, 50);
    }

    function isValidGuardian(data) {
      return hasRequiredFields(['firstName', 'lastName', 'licensePlate']) &&
             validStringLength('firstName', 1, 100) &&
             validStringLength('lastName', 1, 100) &&
             validStringLength('licensePlate', 1, 20);
    }

    function isValidPickup(data) {
      return hasRequiredFields(['studentId', 'guardianId', 'timestamp', 'status']) &&
             data.status in ['pending', 'announced', 'completed'];
    }

    // Rules
    match /students/{studentId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidStudent(request.resource.data);
      allow update: if isAuthenticated() && isValidStudent(request.resource.data);
      allow delete: if isAuthenticated();
    }

    match /guardians/{guardianId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidGuardian(request.resource.data);
      allow update: if isAuthenticated() && isValidGuardian(request.resource.data);
      allow delete: if isAuthenticated();
    }

    match /pickups/{pickupId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidPickup(request.resource.data);
      allow update: if isAuthenticated() && isValidPickup(request.resource.data);
      allow delete: if isAuthenticated();
    }
  }
}
